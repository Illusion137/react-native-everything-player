{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist",
		"declaration": true,
		"declarationMap": false,
		"sourceMap": true,
		"noEmit": false,
		"module": "CommonJS",
		"moduleResolution": "node",
		"ignoreDeprecations": "6.0",
		"target": "ES2019",
		"jsx": "react-jsx",
		"verbatimModuleSyntax": false
	},
	"include": ["src/**/*"]
}
